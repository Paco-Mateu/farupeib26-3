{
  "name": "nextjs-fastapi",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "demo:start": "bash scripts/start-demo.sh",
    "demo:stop": "bash scripts/stop-demo.sh",
    "security:check": "python3 scripts/secret-audit.py",
    "security:hooks": "bash scripts/install-git-hooks.sh",
    "openai:check": "bash scripts/check-openai.sh",
    "voyage:check": "bash scripts/check-voyage.sh",
    "deploy:check": "bash scripts/deploy-cycle-check.sh",
    "deploy:preview": "bash scripts/deploy-cycle-check.sh --remote-preview",
    "deploy:prod": "bash scripts/deploy-cycle-check.sh --remote-production",
    "vercel:link": "bash scripts/vercel-link.sh",
    "vercel:status": "bash scripts/vercel-project-status.sh",
    "vercel:env:push": "bash scripts/vercel-env-push.sh .env.local",
    "vercel:env:pull:dev": "bash scripts/vercel-env-pull.sh development",
    "vercel:env:pull:preview": "bash scripts/vercel-env-pull.sh preview",
    "vercel:env:pull:prod": "bash scripts/vercel-env-pull.sh production",
    "fastapi-dev": "pip3 install -r requirements.txt && python3 -m uvicorn api.index:app --reload --port ${BACKEND_PORT:-8001}",
    "next-dev": "next dev --port ${FRONTEND_PORT:-3001}",
    "dev": "bash scripts/dev.sh",
    "build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "20.2.4",
    "@types/react": "18.2.7",
    "@types/react-dom": "18.2.4",
    "autoprefixer": "10.4.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^8.0.1",
    "eslint": "8.41.0",
    "eslint-config-next": "13.4.4",
    "framer-motion": "^12.38.0",
    "geist": "^1.7.0",
    "lodash": "^4.17.21",
    "lucide-react": "^1.16.0",
    "next": "^14.2.26",
    "postcss": "8.4.23",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-qr-code": "^2.0.18",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.0.4"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.0"
  }
}
